<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Complete Booking - Campus Facility Booking System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <!-- Navigation Bar (same as dashboard) -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="dashboard.html">
                <i class="fas fa-building me-2"></i>Campus Booking System
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="dashboard.html">
                            <i class="fas fa-tachometer-alt me-1"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="my-bookings.html">
                            <i class="fas fa-calendar-check me-1"></i>My Bookings
                        </a>
                    </li>
                    <li class="nav-item" id="adminMenuNav" style="display: none;">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-user-shield me-1"></i>Admin
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="admin-dashboard.html">Pending Approvals</a></li>
                            <li><a class="dropdown-item" href="admin-facilities.html">Manage Facilities</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <span class="nav-link" id="userNameDisplay"></span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-danger" href="#" id="logoutBtn">
                            <i class="fas fa-sign-out-alt me-1"></i>Logout
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <a href="dashboard.html" class="btn btn-outline-secondary mb-3">
            <i class="fas fa-arrow-left me-1"></i>Cancel
        </a>

        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-header bg-white border-0 pt-4">
                        <h3 class="text-center mb-0">
                            <i class="fas fa-calendar-plus text-primary me-2"></i>
                            Complete Your Booking
                        </h3>
                        <hr>
                    </div>
                    <div class="card-body p-4">
                        <!-- Booking Summary -->
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            <strong>Facility:</strong> <span id="facilityName">Loading...</span><br>
                            <strong>Date:</strong> <span id="bookingDate"></span><br>
                            <strong>Time:</strong> <span id="bookingTime"></span>
                        </div>

                        <!-- Booking Form -->
                        <form id="bookingForm">
                            <div class="mb-3">
                                <label for="purpose" class="form-label fw-bold">
                                    Purpose of Booking <span class="text-danger">*</span>
                                </label>
                                <textarea class="form-control" id="purpose" rows="3" 
                                    placeholder="e.g., Department meeting, Guest lecture, Student event" required></textarea>
                            </div>

                            <div class="mb-3">
                                <label for="attendeeCount" class="form-label fw-bold">
                                    Expected Attendees <span class="text-danger">*</span>
                                </label>
                                <input type="number" class="form-control" id="attendeeCount" 
                                    min="1" required>
                                <small class="text-muted">Maximum capacity: <span id="maxCapacity">0</span></small>
                            </div>

                            <div class="mb-3">
                                <label for="notes" class="form-label fw-bold">Additional Notes (Optional)</label>
                                <textarea class="form-control" id="notes" rows="2" 
                                    placeholder="Any special requirements or setup instructions..."></textarea>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-check-circle me-2"></i>Confirm Booking
                                </button>
                                <a href="dashboard.html" class="btn btn-outline-secondary">
                                    Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modals -->
    <div class="modal fade" id="successModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-body text-center p-4">
                    <i class="fas fa-check-circle text-success fa-4x mb-3"></i>
                    <h5>Booking Submitted Successfully!</h5>
                    <p>Your request is pending approval. You will receive an email confirmation once reviewed.</p>
                </div>
                <div class="modal-footer justify-content-center border-0">
                    <a href="dashboard.html" class="btn btn-success">Return to Dashboard</a>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="errorModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-body text-center p-4">
                    <i class="fas fa-exclamation-circle text-danger fa-4x mb-3"></i>
                    <h5 id="errorMsg">Booking Failed</h5>
                </div>
                <div class="modal-footer justify-content-center border-0">
                    <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Try Again</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <script src="js/api.js"></script>
    <script src="js/booking-form.js"></script>
</body>
</html>
